{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/agent-mcps/catalog/schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "servers"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "servers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "description",
          "transport",
          "envVars",
          "clients",
          "enabled",
          "versionPolicy"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "transport": {
            "type": "string",
            "enum": [
              "stdio",
              "http"
            ]
          },
          "command": {
            "type": "string",
            "minLength": 1
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "envVars": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9_]*$"
            },
            "uniqueItems": true
          },
          "clients": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "claude",
                "codex",
                "cursor"
              ]
            },
            "uniqueItems": true
          },
          "enabled": {
            "type": "boolean"
          },
          "versionPolicy": {
            "type": "string",
            "enum": [
              "pinned"
            ]
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "transport": {
                  "const": "stdio"
                }
              }
            },
            "then": {
              "required": [
                "command",
                "args"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "transport": {
                  "const": "http"
                }
              }
            },
            "then": {
              "required": [
                "url"
              ]
            }
          }
        ]
      }
    }
  }
}
